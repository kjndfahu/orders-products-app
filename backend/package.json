{
  "name": "orders-products-backend",
  "version": "1.0.0",
  "description": "Backend API for Orders and Products Management System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:init": "node dist/scripts/initDatabase.js",
    "db:seed": "node dist/scripts/seedDatabase.js",
    "db:seed-if-empty": "node dist/scripts/seedIfEmpty.js",
    "db:setup": "npm run build && npm run db:init && npm run db:seed-if-empty",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "orders",
    "products",
    "api",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "morgan": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
