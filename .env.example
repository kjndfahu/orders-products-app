# MariaDB Configuration
MARIADB_ROOT_PASSWORD=your_secure_password
MARIADB_DATABASE=orders_products_db

# Backend Database Connection
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=orders_products_db

# Prisma Database URL (must match above settings)
DATABASE_URL=mysql://root:your_secure_password@mysql:3306/orders_products_db

# Backend Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# API Configuration
API_PREFIX=/api/v1

# Frontend Configuration (set in docker-compose.yml as build arg)
# NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
